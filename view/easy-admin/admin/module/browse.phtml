<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Module\Module[] $installedModules
 * @var array $catalogueModules
 * @var \EasyAdmin\Form\AddonManageForm $manageForm
 * @var \EasyAdmin\Form\AddonsForm $installForm
 * @var callable $stateForm
 * @var string|null $filterState
 * @var \Omeka\Module\Manager $moduleManager
 * @var \EasyAdmin\Form\ModuleStateForm|null $selectionForm
 */

use Omeka\Module\Manager;

$plugins = $this->getHelperPluginManager();
$url = $plugins->get('url');
$escape = $plugins->get('escapeHtml');
$assetUrl = $plugins->get('assetUrl');
$translate = $plugins->get('translate');
$hyperlink = $plugins->get('hyperlink');

$this->headLink()
    ->appendStylesheet($assetUrl('css/easy-admin.css', 'EasyAdmin'));
$this->htmlElement('body')->appendAttribute('class', 'modules browse easy-admin');

$composerAddonsPath = OMEKA_PATH . '/composer-addons/modules';

$states = [
    Manager::STATE_ACTIVE => $translate('Active'),
    Manager::STATE_NOT_ACTIVE => $translate('Not active'),
    Manager::STATE_NOT_INSTALLED => $translate('Not installed'),
    Manager::STATE_NEEDS_UPGRADE => $translate('Needs upgrade'),
    Manager::STATE_NOT_FOUND => $translate('Not found'),
    Manager::STATE_INVALID_MODULE => $translate('Invalid module'),
    Manager::STATE_INVALID_INI => $translate('Invalid INI'),
    Manager::STATE_INVALID_OMEKA_VERSION => $translate('Invalid Omeka S version'),
];
?>

<?= $this->pageTitle($translate('Manage modules'), 1, $translate('Easy Admin')) ?>

<nav class="section-nav">
    <?= $this->navigation('Laminas\Navigation\EasyAdmin')->menu() ?>
</nav>

<?php if (!is_writeable(OMEKA_PATH . '/modules')): ?>
<div class="messages error">
    <p><?= $escape(sprintf($translate('The directory "%s" is not writeable. Module installation, update and removal are disabled.'), 'modules/')) ?></p>
</div>
<?php endif ?>

<div id="page-actions">
    <?php if ($selectionForm): ?>
    <a class="button sidebar-content" data-sidebar-selector="#sidebar-selection"><?= $escape($translate('Install a selection')) ?></a>
    <?php endif ?>
    <a class="button sidebar-content" data-sidebar-selector="#sidebar-install"><?= $escape($translate('Install new module')) ?></a>
</div>

<br/>

<form method="get" class="state-filter">
    <select name="state" aria-label="<?= $translate('Filter') ?>">
        <option value=""><?= $translate('All modules') ?></option>
        <?php foreach (['active', 'not_active', 'not_installed', 'needs_upgrade'] as $s): ?>
        <option value="<?= $escape($s) ?>"<?= $filterState === $s ? ' selected' : '' ?>><?= $escape($states[$s] ?? $s) ?></option>
        <?php endforeach ?>
        <option value="error"<?= $filterState === 'error' ? ' selected' : '' ?>><?= $escape($translate('Error')) ?></option>
    </select>
</form>

<?php if ($installedModules): ?>

<?php
$manageForm
    ->prepare()
    ->setAttribute('action', $url('admin/easy-admin/default', ['controller' => 'module']))
    ->setAttribute('method', 'post')
    ->setAttribute('id', 'batch-form')
    ->setAttribute('class', 'disable-unsaved-warning');

echo $this->form()->openTag($manageForm);
?>

<div class="batch-inputs">
    <select class="batch-actions-select" name="bulk_action" aria-label="<?= $translate('Batch actions') ?>">
        <option value="default"><?= $translate('Batch actions') ?></option>
        <option value="activate" disabled="disabled"><?= $escape($translate('Activate selected')) ?></option>
        <option value="deactivate" disabled="disabled"><?= $escape($translate('Deactivate selected')) ?></option>
        <option value="update" disabled="disabled"><?= $escape($translate('Update selected')) ?></option>
        <option value="remove" disabled="disabled"><?= $escape($translate('Remove selected')) ?></option>
    </select>
    <div class="batch-actions">
        <button type="button" class="default active" disabled="disabled"><?= $translate('Go') ?></button>
        <button type="submit" class="activate" name="batch_submit" value="activate" style="display:none"><?= $translate('Go') ?></button>
        <button type="submit" class="deactivate" name="batch_submit" value="deactivate" style="display:none"><?= $translate('Go') ?></button>
        <button type="submit" class="update" name="batch_submit" value="update" style="display:none"><?= $translate('Go') ?></button>
        <a class="delete button sidebar-content remove" data-sidebar-selector="#sidebar-remove-selected" style="display:none"><?= $translate('Go') ?></a>
    </div>
</div>

<table class="tablesaw batch-edit" data-tablesaw-mode="stack">
    <thead>
        <tr>
            <th>
                <input type="checkbox" class="select-all" aria-label="<?= $translate('Select all') ?>">
                <?= $translate('Module') ?>
            </th>
            <th><?= $translate('Version') ?></th>
            <th><?= $translate('State') ?></th>
        </tr>
    </thead>
    <tbody>
    <?php foreach ($installedModules as $moduleId => $module):
        $state = $module->getState();
        $errorStates = [
            Manager::STATE_NOT_FOUND,
            Manager::STATE_INVALID_MODULE,
            Manager::STATE_INVALID_INI,
            Manager::STATE_INVALID_OMEKA_VERSION,
        ];
        if ($filterState === 'error' && !in_array($state, $errorStates)) {
            continue;
        } elseif ($filterState && $filterState !== 'error' && $state !== $filterState) {
            continue;
        }
        $isComposer = is_dir($composerAddonsPath . '/' . $moduleId);
        $ini = $module->getIni();
        $version = $ini['version'] ?? '';
        $name = $module->getName() ?: $moduleId;

        $catalogueVersion = null;
        foreach ($catalogueModules as $cm) {
            if (($cm['dir'] ?? '') === $moduleId) {
                $catalogueVersion = $cm['version'] ?? null;
                break;
            }
        }
        $hasUpdate = $catalogueVersion
            && $version
            && version_compare($version, $catalogueVersion, '<');
    ?>
        <tr>
            <td>
                <?php if (!$isComposer): ?>
                <input type="checkbox" name="modules[]" value="<?= $escape($moduleId) ?>" aria-label="<?= $escape(sprintf($translate('Select %s'), $name)) ?>">
                <?php endif ?>

                <?php if ($moduleLink = $module->getIni('module_link')): ?>
                <?= $hyperlink($name, $moduleLink, ['target' => '_blank']) ?>
                <?php else: ?>
                <strong><?= $escape($name) ?></strong>
                <?php endif ?>

                <?php if ($author = $module->getIni('author')): ?>
                <span class="addon-author"> — <?= $escape($author) ?></span>
                <?php endif ?>
                <?php if ($description = $module->getIni('description')): ?>
                <span class="addon-description"><?= $escape($description) ?></span>
                <?php endif ?>

                <ul class="actions">
                    <?php if (!$isComposer): ?>

                        <?php if (Manager::STATE_NOT_ACTIVE === $state): ?>
                        <li>
                            <?php $form = $stateForm('activate', $moduleId); $form->prepare(); echo $this->form($form); ?>
                        </li>
                        <?php endif ?>

                        <?php if (Manager::STATE_ACTIVE === $state): ?>
                        <li>
                            <?php $form = $stateForm('deactivate', $moduleId); $form->prepare(); echo $this->form($form); ?>
                        </li>
                        <?php endif ?>

                        <?php if (Manager::STATE_NEEDS_UPGRADE === $state): ?>
                        <li>
                            <?php $form = $stateForm('upgrade', $moduleId); $form->prepare(); echo $this->form($form); ?>
                        </li>
                        <?php endif ?>

                        <?php if ($hasUpdate): ?>
                        <li><?= $hyperlink('', '#', [
                            'data-sidebar-selector' => '#sidebar',
                            'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'update-confirm'], ['query' => ['id' => $moduleId]]),
                            'class' => 'o-icon-install sidebar-content',
                            'title' => $translate('Update files'),
                        ]) ?></li>
                        <?php endif ?>

                        <?php if (in_array($state, [
                            Manager::STATE_ACTIVE,
                            Manager::STATE_NOT_ACTIVE,
                            Manager::STATE_NOT_INSTALLED,
                            Manager::STATE_INVALID_MODULE,
                            Manager::STATE_INVALID_INI,
                            Manager::STATE_INVALID_OMEKA_VERSION,
                        ])): ?>
                        <li><?= $hyperlink('', '#', [
                            'data-sidebar-selector' => '#sidebar',
                            'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'remove-confirm'], ['query' => ['id' => $moduleId]]),
                            'class' => 'o-icon-delete sidebar-content',
                            'title' => $translate('Remove'),
                        ]) ?></li>
                        <?php endif ?>

                    <?php endif ?>

                    <?php if ($isComposer): ?>
                    <li><span class="o-icon-lock" aria-label="Composer" title="<?= $escape($translate('Managed by Composer')) ?>"></span></li>
                    <?php endif ?>

                    <li><?= $hyperlink('', '#', [
                        'data-sidebar-selector' => '#sidebar',
                        'data-sidebar-content-url' => $url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'show-details'], ['query' => ['id' => $moduleId]]),
                        'class' => 'o-icon-more sidebar-content',
                        'title' => $translate('Details'),
                    ]) ?></li>
                </ul>
            </td>
            <td class="col-version<?= $hasUpdate ? ' has-update' : '' ?>">
                <?= $escape($version) ?>
                <?php if ($hasUpdate): ?>
                <?= sprintf($translate('→ %s'), $escape($catalogueVersion)) ?>
                <?php endif ?>
            </td>
            <td class="col-state">
                <span><?= $escape($states[$state] ?? $state) ?></span>
                <?php if ($state === Manager::STATE_INVALID_MODULE): ?>
                <span class="error"><?= $translate('Error: invalid Module.php') ?></span>
                <?php elseif ($state === Manager::STATE_INVALID_INI): ?>
                <span class="error"><?= $translate('Error: invalid module.ini') ?></span>
                <?php elseif ($state === Manager::STATE_INVALID_OMEKA_VERSION): ?>
                <span class="error"><?= sprintf($translate('Requires Omeka S %s'), $module->getIni('omeka_version_constraint')) ?></span>
                <?php elseif ($state === Manager::STATE_NOT_FOUND): ?>
                <span class="error"><?= $translate('Not in filesystem') ?></span>
                <?php endif ?>
            </td>
        </tr>
    <?php endforeach ?>
    </tbody>
</table>

<?= $this->form()->closeTag($manageForm) ?>

<div id="sidebar" class="sidebar">
    <?= $hyperlink('', '#', [
        'class' => 'sidebar-close o-icon-close',
        'title' => $translate('Close'),
    ]) ?>
    <div class="sidebar-content"></div>
</div>

<?php else: ?>
<div class="no-resources">
    <p><?= $translate('No modules found.') ?></p>
</div>
<?php endif ?>

<div id="sidebar-install" class="sidebar">
    <?= $hyperlink('', '#', [
        'class' => 'sidebar-close o-icon-close',
        'title' => $translate('Close'),
    ]) ?>
    <div class="sidebar-content">
        <h3><?= $escape($translate('Install new module from catalogue')) ?></h3>
        <p class="explanation">
            <?= sprintf($translate('For more information, see pages of known %1$smodules%2$s or %3$sOmeka.org%2$s.'),
                '<a href="https://daniel-km.github.io/UpgradeToOmekaS/omeka_s_modules.html" rel="noopener" target="_blank">', '</a>',
                '<a href="https://omeka.org/s/modules/" rel="noopener" target="_blank">') ?>
            <?= $translate('Modules with an asterisk are already downloaded.') ?>
        </p>
        <?php
        $installForm->prepare()
            ->setAttribute('action', $url('admin/easy-admin/default', ['controller' => 'module', 'action' => 'install']))
            ->setAttribute('method', 'post');
        echo $this->form()->openTag($installForm);
        ?>
        <div class="field">
            <label for="module_url"><?= $escape($translate('Select a module')) ?></label>
            <select name="module_url" id="module_url" class="chosen-select">
                <option value=""><?= $escape($translate('Select below…')) ?></option>
                <?php foreach ($catalogueModules as $catUrl => $catModule):
                    $label = $catModule['name'];
                    $label .= !empty($catModule['version']) ? ' [v' . $catModule['version'] . ']' : '';
                    $label .= !empty($catModule['installed']) ? ' *' : '';
                ?>
                <option value="<?= $escape($catUrl) ?>"<?= !empty($catModule['installed']) ? ' disabled' : '' ?>><?= $escape($label) ?></option>
                <?php endforeach ?>
            </select>
        </div>
        <button type="submit" class="button"><?= $escape($translate('Install')) ?></button>
        <?= $this->form()->closeTag($installForm) ?>
    </div>
</div>

<?php if ($selectionForm): ?>
<div id="sidebar-selection" class="sidebar">
    <?= $hyperlink('', '#', [
        'class' => 'sidebar-close o-icon-close',
        'title' => $translate('Close'),
    ]) ?>
    <div class="sidebar-content">
        <h3><?= $escape($translate('Install a curated selection')) ?></h3>
        <p><?= $escape($translate('Install a preconfigured set of modules and themes in one step.')) ?></p>
        <?php
        $selectionForm->prepare();
        echo $this->form()->openTag($selectionForm);
        ?>
        <div class="field">
            <?= $this->formElement($selectionForm->get('selection')) ?>
        </div>
        <button type="submit" class="button"><?= $escape($translate('Install')) ?></button>
        <?= $this->form()->closeTag($selectionForm) ?>
    </div>
</div>
<?php endif ?>

<script>
$('.state-filter select').change(function() {
    $(this).closest('form').submit();
});
</script>
