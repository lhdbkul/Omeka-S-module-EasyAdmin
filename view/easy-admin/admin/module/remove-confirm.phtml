<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var array|null $addon
 * @var string $addonDir
 * @var array $integrity
 * @var \EasyAdmin\Form\ModuleStateForm $form
 */

$plugins = $this->getHelperPluginManager();
$escape = $plugins->get('escapeHtml');
$translate = $plugins->get('translate');
$formElement = $plugins->get('formElement');

$name = $addon['name'] ?? $addonDir;
?>

<div id="sidebar-confirm">
    <h3><?= $escape(sprintf($translate('Remove module "%s"'), $name)) ?></h3>
    <p><?= $escape(sprintf(
        $translate('Are you sure you would like to remove the module %s?'),
        $name
    )) ?></p>
    <p class="error"><?= sprintf(
        $translate('%1$s: this action will uninstall the module from the database and delete all its files. This cannot be undone.'),
        sprintf('<strong>%s</strong>', $escape($translate('Warning')))
    ) ?></p>
    <?php if ($integrity['status'] === 'modified'): ?>
    <p class="error"><?= $escape($translate('This module has been modified locally.')) ?></p>
    <?php endif ?>
    <?php
    $form->prepare();
    echo $this->form()->openTag($form);
    echo $formElement($form->get('id'));
    ?>
    <input type="submit" value="<?= $escape($translate('Confirm removal')) ?>">
    <?= $this->form()->closeTag($form) ?>
</div>
